# -----------------------------------------------------------------------------
# Variables de SERVIDOR (solo usadas dentro de api/*.ts, en Vercel). Nunca deben
# llevar el prefijo VITE_: eso evitaría que Vite las incluya por error en el
# bundle del navegador.
# -----------------------------------------------------------------------------

# URL del proyecto de Supabase. Ej: https://xxxxxxxxxxxx.supabase.co
SUPABASE_URL=

# Service role key de Supabase (Project Settings > API). Bypassa RLS: es secreta,
# jamás debe usarse en el frontend ni commitearse.
SUPABASE_SERVICE_ROLE_KEY=

# Sal secreta usada para hashear la IP de origen antes de guardarla (control de
# abuso/rate limiting). Cualquier string largo y aleatorio sirve.
IP_HASH_SALT=

# -----------------------------------------------------------------------------
# Variables PÚBLICAS (prefijo VITE_: Vite las incluye en el bundle del cliente).
# No poner acá ningún secreto.
# -----------------------------------------------------------------------------

# URL canónica del sitio, usada en SEO/Open Graph/sitemap.
VITE_SITE_URL=https://inversionespyp.com.ar

# Teléfono de WhatsApp en formato internacional sin signos. Ej: 5491122334455
VITE_WHATSAPP_PHONE=

# Google Analytics 4 (Measurement ID, ej: G-XXXXXXXXXX). Vacío = deshabilitado.
VITE_GA4_MEASUREMENT_ID=

# Google Tag Manager (Container ID, ej: GTM-XXXXXXX). Vacío = deshabilitado.
VITE_GTM_CONTAINER_ID=

# Meta Pixel (Pixel ID). Vacío = deshabilitado.
VITE_META_PIXEL_ID=
